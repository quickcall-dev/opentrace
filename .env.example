# QuickCall OpenTrace — Environment Variables
# Copy to .env and adjust for your setup.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Connection string for the ingest server.
QUICKCALL_OPENTRACE_DSN=postgresql://quickcall:quickcall@localhost:5432/quickcall

# ── Server (ingest API) ─────────────────────────────────────────────────────
# Host to bind the HTTP server on.
QUICKCALL_OPENTRACE_HOST=0.0.0.0

# Port to bind the HTTP server on (default: 19777).
QUICKCALL_OPENTRACE_PORT=19777

# Comma-separated API keys for admin endpoints (/api/*, /stats, /sync).
QUICKCALL_OPENTRACE_ADMIN_KEYS=admin_dev

# Comma-separated API keys for ingest pushes from the daemon.
QUICKCALL_OPENTRACE_PUSH_KEYS=push_dev

# ── Daemon ──────────────────────────────────────────────────────────────────
# Full URL the daemon pushes batches to.
QUICKCALL_OPENTRACE_INGEST_URL=http://localhost:19777/ingest

# API key the daemon sends with each push.
# Must match one of the QUICKCALL_OPENTRACE_PUSH_KEYS configured on the server.
QUICKCALL_OPENTRACE_API_KEY=push_dev

# Organization slug (optional). Tags all sessions with this org.
QUICKCALL_OPENTRACE_ORG=

# Max files to process per poll cycle (0 = unlimited).
QUICKCALL_OPENTRACE_MAX_FILES=0

# Enable per-poll profiling output (set to 1 to enable).
QUICKCALL_OPENTRACE_PROFILE_POLLS=0

# ── Config / State ──────────────────────────────────────────────────────────
# Directory for daemon state, PID, and repo cache.
# Default: ~/.quickcall-opentrace
QUICKCALL_OPENTRACE_CONFIG_DIR=
