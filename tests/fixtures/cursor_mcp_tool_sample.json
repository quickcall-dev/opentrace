{
  "name": "read_file",
  "description": "Read the contents of a file at the specified path.\n\nArgs:\n    path: Absolute path to the file to read\n    encoding: Character encoding (default: utf-8)\n\nReturns:\n    File contents as a string",
  "arguments": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Absolute path to the file"
      },
      "encoding": {
        "type": "string",
        "default": "utf-8",
        "description": "Character encoding"
      }
    },
    "required": ["path"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "content": {
        "type": "string"
      },
      "size": {
        "type": "integer"
      }
    },
    "additionalProperties": true
  }
}
